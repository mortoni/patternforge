{
  "name": "patternforge",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-only",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "next build && next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "vitest run",
    "ci": "pnpm run lint && pnpm run test && pnpm run typecheck && pnpm run build",
    "test:watch": "vitest",
    "test:e2e": "node node_modules/@playwright/test/cli.js test",
    "test:e2e:install": "node node_modules/@playwright/test/cli.js install chromium",
    "validate:woodpecker": "tsx scripts/validate-woodpecker-json.ts",
    "validate:woodpecker:ci": "tsx scripts/validate-woodpecker-json.ts --ci --fail-on-issues",
    "repair:woodpecker": "tsx scripts/repair-woodpecker-from-comments.ts",
    "normalize:woodpecker-comments": "tsx scripts/normalize-woodpecker-comments.ts",
    "fill:missing-easy-comments": "tsx scripts/fill-missing-easy-comments.ts",
    "generate:icons": "tsx scripts/generate-icons.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
